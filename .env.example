# Backend API base URL (can be absolute like http://localhost:4000/api or relative like /api)
VITE_API_BASE_URL=http://localhost:4000/api

# CustomPdfBuilder (Editor) URL used when switching from Scene → Editor
VITE_EDITOR_URL=http://localhost:5173/

# Temporary auth token shared with the Editor (passed out-of-band via window.name)
VITE_PDF_BUILDER_AUTH_TOKEN=dummy_auth_token_42

